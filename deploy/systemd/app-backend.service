[Unit]
Description=App Backend (FastAPI + Uvicorn)
After=network.target

[Service]
Type=simple
User=app
Group=app
WorkingDirectory=/opt/app/current/backend
EnvironmentFile=/etc/app/app.env
ExecStart=/opt/app/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
